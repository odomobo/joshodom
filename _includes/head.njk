<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

{# Page title #}
<title>
  {%- if title and title != site.title -%}
    {{ title }} | {{ site.title }}
  {%- else -%}
    {{ site.title }}
  {%- endif -%}
</title>

{# SEO meta #}
<meta name="description" content="{{ description or site.description }}">

{# Open Graph #}
<meta property="og:title" content="{{ title or site.title }}">
<meta property="og:description" content="{{ description or site.description }}">
<meta property="og:type" content="{% if layout == 'post' %}article{% else %}website{% endif %}">
<meta property="og:url" content="{{ page.url | url | absoluteUrl(site.url) }}">

{# Canonical #}
<link rel="canonical" href="{{ page.url | url | absoluteUrl(site.url) }}">

{# RSS autodiscovery #}
<link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="{{ site.url }}feed.xml">

{# Stylesheet #}
<link rel="stylesheet" href="/assets/css/main.css">
