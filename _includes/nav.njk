<nav class="nav" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-title">{{ site.title }}</a>

    <button
      class="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
    >&#9776;</button>

    <div class="nav-right" id="nav-menu">
      <ul class="nav-links">
        {% for link in site.nav_links %}
          <li>
            <a
              href="{{ link.url }}"
              class="{% if page.url == link.url or (page.url.startsWith(link.url) and link.url != '/') %}active{% endif %}"
              {% if page.url == link.url or (page.url.startsWith(link.url) and link.url != '/') %}aria-current="page"{% endif %}
            >{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>

      <form class="search-form" action="https://duckduckgo.com/" method="GET" role="search">
        <input type="hidden" name="sites" value="{{ site.url }}">
        <input
          class="search-input"
          type="text"
          name="q"
          placeholder="Search…"
          aria-label="Search this site"
        >
      </form>
    </div>
  </div>
</nav>
