---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ site.url }}feed.xml" rel="self" />
  <link href="{{ site.url }}" />
  <updated>{{ collections.posts | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
  <id>{{ site.url }}</id>
  <author>
    <name>{{ site.author.name }}</name>
  </author>
  {%- for post in collections.posts | limit(20) %}
  <entry>
    <title>{{ post.data.title | escape }}</title>
    <link href="{{ post.url | absoluteUrl(site.url) }}" />
    <updated>{{ post.date | dateToRfc3339 }}</updated>
    <id>{{ post.url | absoluteUrl(site.url) }}</id>
    {% if post.data.description %}<summary>{{ post.data.description | escape }}</summary>{% endif %}
    <content type="html">{{ post.templateContent | htmlToAbsoluteUrls(site.url) | escape }}</content>
  </entry>
  {%- endfor %}
</feed>
