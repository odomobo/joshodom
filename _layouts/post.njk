---
layout: base
---
{% set neighbors = collections.posts | postNeighbors(page.url) %}

<article>

  <header class="post-header">
    <h1 class="post-title">{{ title }}</h1>
    {% if description %}
      <p class="post-lede">{{ description }}</p>
    {% endif %}
    <div class="post-meta">
      <time datetime="{{ date | htmlDateStr }}">{{ date | dateDisplay }}</time>
      <span class="separator">·</span>
      <span>{{ site.author.name }}</span>
      {% if tags and tags.length %}
        <span class="separator">·</span>
        {% include "tag-list.njk" %}
      {% endif %}
    </div>
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>

  <footer class="post-footer-meta">
    <div class="post-meta">
      <time datetime="{{ date | htmlDateStr }}">{{ date | dateDisplay }}</time>
      <span class="separator">·</span>
      <span>{{ site.author.name }}</span>
      {% if tags and tags.length %}
        <span class="separator">·</span>
        {% include "tag-list.njk" %}
      {% endif %}
    </div>
  </footer>

  <nav class="post-nav" aria-label="Post navigation">
    {% if neighbors.prev %}
      <a href="{{ neighbors.prev.url }}" class="post-nav-item prev">
        <span class="post-nav-label">‹ Previous</span>
        <span class="post-nav-title">{{ neighbors.prev.data.title }}</span>
      </a>
    {% else %}
      <div class="post-nav-placeholder"></div>
    {% endif %}
    {% if neighbors.next %}
      <a href="{{ neighbors.next.url }}" class="post-nav-item next">
        <span class="post-nav-label">Next ›</span>
        <span class="post-nav-title">{{ neighbors.next.data.title }}</span>
      </a>
    {% else %}
      <div class="post-nav-placeholder"></div>
    {% endif %}
  </nav>

</article>
